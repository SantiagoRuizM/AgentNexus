---
---
<footer class="main-footer">
  <div class="content-wrapper">
    <div class="footer-left">
      <img src="/assets/+Logosímbolo+Universidad+de+Antioquia+horizontal+blanco.png" alt="Universidad de Antioquia" height="28" style="width:auto;object-fit:contain;opacity:.9;" />
      <span class="separator-v"></span>
      <span class="wordmark">UdeAyuda.</span>
    </div>
    <div class="footer-right mono">
      <span>MVP · 24h</span>
      <span class="separator">·</span>
      <span>Facultad de Ingeniería</span>
      <span class="separator">·</span>
      <span>UdeA · 2026</span>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background: var(--ink);
    padding: 2rem 0;
    color: white;
  }

  .content-wrapper {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Azurio', serif;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .separator-v {
    width: 1px; height: 1.4rem;
    background: rgba(255,255,255,0.25);
    display: inline-block;
  }

  .footer-right {
    font-size: 0.72rem;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .separator {
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .content-wrapper {
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
