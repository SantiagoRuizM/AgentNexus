---

<nav id="main-nav">
  <div class="nav-content">
    <div class="nav-left">
      <img src="/assets/Isologo_transparente.png" alt="AgentNexus Logo" width="26" height="26" />
      <span class="wordmark">AgentNexus<span class="grad-text">.</span></span>
    </div>
    
    <div class="nav-links">
      <a href="#reto">Manifiesto Nexus</a>
      <a href="#agentes">Agentes</a>
      <a href="#arquitectura">Arquitectura</a>
      <a href="#fuentes">Fuentes</a>
    </div>

    <div class="nav-right">
      <a href="/roles" class="cta-button cta-enter">
        <span class="dot pulse"></span>
        Probar el copiloto
        <span class="arrow-pill">→</span>
      </a>
    </div>
  </div>
</nav>

<style>
  #main-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    transition: all 0.3s ease;
    padding: 1rem 0;
  }
  
  #main-nav.scrolled {
    background: rgba(255, 255, 255, 0.75);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--line);
    padding: 0.75rem 0;
  }

  .nav-content {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Azurio', serif;
    font-size: 1.25rem;
    font-weight: 500;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .nav-links a {
    color: var(--muted);
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--ink);
  }

  .pill-badge {
    font-size: 0.75rem;
    background: var(--cream-02);
    padding: 0.25rem 0.5rem;
    border-radius: 999px;
    color: var(--muted);
    border: 1px solid var(--line);
  }

  .cta-button {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: var(--ink);
    color: white;
    padding: 0.4rem 0.4rem 0.4rem 1rem;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: transform 0.2s;
  }
  .cta-button:hover {
    transform: translateY(-2px);
  }

  .dot {
    width: 6px;
    height: 6px;
    background: var(--coral-500);
    border-radius: 50%;
    display: inline-block;
  }
  .dot.pulse {
    animation: pulse 2s infinite ease-in-out;
  }

  .arrow-pill {
    background: var(--grad-orange);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    display: inline-block;
  }

  @media (max-width: 880px) {
    .nav-links {
      display: none;
    }
  }
</style>

<script>
  window.addEventListener('scroll', () => {
    const nav = document.getElementById('main-nav');
    if (nav) {
      if (window.scrollY > 60) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }
  });
</script>
