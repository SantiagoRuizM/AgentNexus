---
---

<section class="hero-section">
  <div class="hero-bg">
    <video autoplay loop muted playsinline class="hero-video" aria-hidden="true">
      <source src="https://assets.softserveinc.com/download/assets/hero-home-video.mp4" type="video/mp4" />
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-fade"></div>
  </div>

  <div class="hero-content">
    <div class="hero-inner">

      <span class="eyebrow">Orquestador de agentes de conocimiento</span>

      <h1 class="display">
        Tu copiloto académico: respuestas claras,
        sin perderte entre <em class="grad-text">PDFs</em>.
      </h1>

      <p class="lede">
        AgentNexus orquesta una red de agentes especializados sobre tu base documental institucional. Consulta reglamentos, procesos y trámites en lenguaje natural — con citas exactas al artículo, parágrafo y fuente original.
      </p>

      <div class="cta-row">
        <a href="/pregunta-al-agente" class="btn-primary cta-enter">
          <span class="dot-pulse"></span>
          Probar el copiloto
          <span class="arrow-pill">→</span>
        </a>
        <a href="#agentes" class="btn-ghost">Ver los agentes</a>
      </div>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-num grad-text">4</span>
          <span class="stat-lbl">Agentes IA</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num grad-text">0</span>
          <span class="stat-lbl">Alucinaciones</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat">
          <span class="stat-num grad-text">100%</span>
          <span class="stat-lbl">Citado y verificado</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--grad-warm-bg);
  }

  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
    mix-blend-mode: multiply;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(255, 130, 80, 0.07);
  }

  .hero-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 30%;
    background: linear-gradient(to bottom, transparent, var(--paper));
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 var(--gutter);
    width: 100%;
    padding-top: 48px;
  }

  .hero-inner {
    max-width: 52rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Eyebrow pill */
  .eyebrow {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--coral-600);
    background: rgba(255, 122, 82, 0.1);
    border: 1px solid rgba(255, 122, 82, 0.28);
    padding: 0.3rem 0.85rem;
    border-radius: 999px;
  }

  /* Headline — ensure grad-text is never clipped */
  .display {
    font-size: clamp(2.1rem, 4.2vw, 3.8rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0;
    padding-bottom: 0.08em; /* prevent descender/gradient clip */
  }

  /* Ensure all grad-text has room to render */
  .grad-text {
    display: inline-block;
    padding-bottom: 0.05em;
  }

  .lede {
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    max-width: 38rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* CTAs */
  .cta-row {
    display: flex;
    gap: 0.875rem;
    align-items: center;
    flex-wrap: wrap;
    margin: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: var(--ink);
    color: white;
    padding: 0.65rem 0.65rem 0.65rem 1.15rem;
    border-radius: 999px;
    font-weight: 500;
    font-size: 0.95rem;
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    white-space: nowrap;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.18);
  }

  .dot-pulse {
    width: 7px;
    height: 7px;
    background: var(--coral-400);
    border-radius: 50%;
    display: inline-block;
    animation: pulse 2s infinite;
    flex-shrink: 0;
  }

  .arrow-pill {
    background: var(--grad-orange);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    font-size: 0.95rem;
  }

  .btn-ghost {
    padding: 0.65rem 1.35rem;
    border-radius: 999px;
    border: 1.5px solid var(--line-strong);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--ink);
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-ghost:hover {
    border-color: var(--ink);
    background: rgba(0,0,0,0.03);
  }

  /* Stats glassmorphism bar */
  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.1rem 1.75rem;
    background: rgba(255, 255, 255, 0.52);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.8);
    border-radius: 14px;
    width: fit-content;
    box-shadow: 0 4px 20px rgba(229, 92, 50, 0.08);
    margin: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    min-width: 70px;
    text-align: center;
  }

  .stat-num {
    font-family: 'Azurio', serif;
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 1;
  }

  .stat-lbl {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .stat-div {
    width: 1px;
    height: 2rem;
    background: var(--line-strong);
    flex-shrink: 0;
    opacity: 0.5;
  }

  .mono { font-family: 'JetBrains Mono', monospace; }

  @media (max-width: 768px) {
    .hero-content { padding-top: 80px; }
    .display { font-size: clamp(1.9rem, 6vw, 2.8rem); }
    .stats-row { gap: 1rem; padding: 0.9rem 1.25rem; }
    .stat-num { font-size: 1.3rem; }
    .stat-div { height: 1.5rem; }
  }

  @media (max-width: 480px) {
    .stats-row { flex-wrap: wrap; justify-content: center; }
    .stat-div { display: none; }
  }
</style>
