---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="UdeAyuda: agente universitario de la Universidad de Antioquia para consultar reglamentos, trámites y normas institucionales." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/assets/logosimbolo-vertical.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
