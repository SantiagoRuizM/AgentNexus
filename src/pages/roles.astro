---
import BaseLayout from '../layouts/Base.astro';
---

<BaseLayout title="AgentNexus | Selecciona tu perfil">
  <div class="roles-page">
    <canvas id="field"></canvas>
    
    <div id="cursor"></div>

    <div class="roles-layout">
      <!-- ROW 1: NAV -->
      <nav class="roles-nav">
        <a href="/" class="logo-link">
          <img src="/assets/isologo.png" alt="AgentNexus Logo" width="26" height="26" class="invert" />
          <span class="wordmark">AgentNexus.</span>
        </a>
        <a href="/" class="back-pill mono">← Volver</a>
      </nav>

      <!-- ROW 2: HEADER -->
      <header class="roles-header">
        <span class="eyebrow mono"><span class="dot"></span>Selecciona tu perfil</span>
        <h1 class="display">¿Quién <em class="grad-text">pregunta</em>?</h1>
      </header>

      <!-- ROW 3: GRID -->
      <div class="roles-grid">
        <!-- Role 01 -->
        <button class="role-card" data-role="01" data-name="Reglamento">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Estudiante · 01</span>
            <h3 class="role-name">Reglamento</h3>
            <span class="role-target mono">→ activa REGLAMENTA</span>
          </div>
          <div class="role-arrow">→</div>
        </button>

        <!-- Role 02 -->
        <button class="role-card" data-role="02" data-name="Matrícula">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Estudiante · 02</span>
            <h3 class="role-name">Matrícula</h3>
            <span class="role-target mono">→ activa MATRÍCULA</span>
          </div>
          <div class="role-arrow">→</div>
        </button>

        <!-- Role 03 -->
        <button class="role-card" data-role="03" data-name="Trámite">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Estudiante · 03</span>
            <h3 class="role-name">Trámite</h3>
            <span class="role-target mono">→ activa TRÁMITE</span>
          </div>
          <div class="role-arrow">→</div>
        </button>

        <!-- Role 04 -->
        <button class="role-card" data-role="04" data-name="Oficio">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Admin · 04</span>
            <h3 class="role-name">Oficio</h3>
            <span class="role-target mono">→ activa OFICIO</span>
          </div>
          <div class="role-arrow">→</div>
        </button>

        <!-- Role 05 -->
        <button class="role-card" data-role="05" data-name="Citador">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Admin · 05</span>
            <h3 class="role-name">Citador</h3>
            <span class="role-target mono">→ activa CITADOR</span>
          </div>
          <div class="role-arrow">→</div>
        </button>

        <!-- Role 06 -->
        <button class="role-card" data-role="06" data-name="Auditor">
          <div class="circle-deco"></div>
          <div class="card-content">
            <span class="role-num mono">Admin · 06</span>
            <h3 class="role-name">Auditor</h3>
            <span class="role-target mono">→ activa AUDITOR</span>
          </div>
          <div class="role-arrow">→</div>
        </button>
      </div>

      <!-- ROW 4: FOOTER -->
      <footer class="roles-footer mono">
        <span>06 perfiles · ⌘+1-6 para activar</span>
        <span>MVP · 24h · Facultad de Ingeniería · UdeA</span>
      </footer>
    </div>

    <!-- NAVIGATION OVERLAY -->
    <div id="agent-overlay" class="agent-overlay">
      <div class="overlay-content">
        <img src="/assets/isologo.png" alt="AgentNexus" width="64" height="64" class="invert mb-4 pulse" />
        <h2 id="agent-overlay-name" class="grad-text overlay-name">Agente</h2>
        <div class="spinner"></div>
        <div class="message mono">Activando agente… demo Gradio</div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  html, body {
    overflow: hidden;
    margin: 0;
    padding: 0;
  }

  .roles-page {
    position: relative;
    width: 100vw;
    height: 100vh;
    background: radial-gradient(140% 90% at 80% 5%, rgba(255,130,80,0.65), transparent 55%),
                radial-gradient(80% 60% at 5% 10%, rgba(255,180,140,0.5), transparent 65%),
                linear-gradient(180deg, #FFC9A8 0%, #FFEFE6 40%, #FFF6EE 72%, #FFFCFA 90%, #FFFFFF 100%);
    cursor: none; /* Custom cursor */
  }

  #field {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    width: 100%;
    height: 100%;
  }

  #cursor {
    position: fixed;
    top: 0;
    left: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(255,255,255,0.4);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.8);
    pointer-events: none;
    z-index: 9999;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, background 0.2s;
  }
  #cursor.hovering {
    width: 56px;
    height: 56px;
    background: rgba(255,255,255,0.1);
  }

  .roles-layout {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    height: 100vh;
    padding: clamp(1.5rem, 4vw, 4rem);
    box-sizing: border-box;
    max-width: 1400px;
    margin: 0 auto;
  }

  .roles-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: 'Azurio', serif;
    font-size: 1.25rem;
    font-weight: 500;
  }
  .invert { filter: invert(1); }
  .back-pill {
    background: rgba(255,255,255,0.5);
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    color: var(--ink);
    border: 1px solid rgba(255,255,255,0.8);
    transition: background 0.2s;
  }
  .back-pill:hover {
    background: white;
  }

  .roles-header {
    text-align: center;
    margin-top: 2rem;
  }
  .eyebrow {
    font-size: 0.85rem;
    color: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .eyebrow .dot {
    width: 6px;
    height: 6px;
    background: var(--ink);
    border-radius: 50%;
  }
  .display {
    font-size: clamp(2.4rem, 4vw, 4rem);
  }

  .roles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 1200px;
    margin: 3rem auto 0 auto;
    width: 100%;
    align-content: center;
  }

  .role-card {
    background: rgba(255, 255, 255, 0.55);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 14px;
    padding: 2rem;
    text-align: left;
    position: relative;
    overflow: hidden;
    cursor: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .role-card:hover {
    background: rgba(255, 255, 255, 0.85);
    border-color: rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(229, 92, 50, 0.15);
  }

  .circle-deco {
    position: absolute;
    top: -20px;
    right: -20px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: var(--coral-500);
    opacity: 0.1;
    transition: all 0.4s ease;
    pointer-events: none;
  }
  .role-card:hover .circle-deco {
    opacity: 0.22;
    transform: scale(1.5);
  }

  .card-content {
    position: relative;
    z-index: 2;
  }
  .role-num {
    font-size: 0.7rem;
    color: var(--muted);
    display: block;
    margin-bottom: 1rem;
  }
  .role-name {
    font-size: 1.5rem;
    font-family: 'Azurio', serif;
    margin-bottom: 0.5rem;
    color: var(--ink);
  }
  .role-target {
    font-size: 0.7rem;
    color: var(--coral-600);
    font-weight: 600;
  }

  .role-arrow {
    position: relative;
    z-index: 2;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--grad-orange);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }
  .role-card:hover .role-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  .roles-footer {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: var(--muted);
    opacity: 0.6;
  }

  /* Overlay */
  .agent-overlay {
    position: fixed;
    inset: 0;
    background: var(--ink);
    z-index: 99999;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translateY(100%);
    transition: transform 620ms cubic-bezier(0.86, 0, 0.07, 1);
  }
  .agent-overlay.active {
    transform: translateY(0);
  }

  .overlay-content {
    text-align: center;
    color: white;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .overlay-name {
    font-size: 3rem;
    font-family: 'Azurio', serif;
    margin-bottom: 2rem;
  }
  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255,255,255,0.1);
    border-top-color: var(--coral-500);
    border-radius: 50%;
    animation: spin 1s linear infinite;
    margin-bottom: 1rem;
  }
  .message {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.6);
  }
  .mb-4 { margin-bottom: 2rem; }
  .pulse { animation: pulse 2s infinite ease-in-out; }

  @media (max-width: 980px) {
    .roles-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .roles-grid { grid-template-columns: 1fr; }
    .roles-layout { padding: 1.5rem; }
  }
</style>

<script>
  // --- Canvas Wave Field ---
  const canvas = document.getElementById('field') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  
  let width = window.innerWidth;
  let height = window.innerHeight;
  let mouse = { x: width/2, y: height/2 };
  let targetMouse = { x: width/2, y: height/2 };
  let time = 0;
  let lastMoveTime = Date.now();
  
  const GAP = 38;
  const INFLUENCE_RADIUS = 220;

  if (canvas && ctx) {
    const resize = () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    };
    window.addEventListener('resize', resize);
    resize();

    window.addEventListener('mousemove', (e) => {
      targetMouse.x = e.clientX;
      targetMouse.y = e.clientY;
      lastMoveTime = Date.now();
    });

    const render = () => {
      time += 0.016;
      
      // Interpolate mouse for smooth halo
      mouse.x += (targetMouse.x - mouse.x) * 0.1;
      mouse.y += (targetMouse.y - mouse.y) * 0.1;

      // Idle orbit
      if (Date.now() - lastMoveTime > 1500) {
        targetMouse.x = width/2 + Math.sin(time * 0.5) * 200;
        targetMouse.y = height/2 + Math.cos(time * 0.4) * 200;
      }

      ctx.clearRect(0, 0, width, height);

      // Draw halo
      const grad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, INFLUENCE_RADIUS);
      grad.addColorStop(0, 'rgba(255, 122, 82, 0.18)');
      grad.addColorStop(1, 'rgba(255, 122, 82, 0)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, width, height);

      // Draw dots
      const cols = Math.ceil(width / GAP);
      const rows = Math.ceil(height / GAP);
      const offsetX = (width % GAP) / 2;
      const offsetY = (height % GAP) / 2;

      for (let i = 0; i <= cols; i++) {
        for (let j = 0; j <= rows; j++) {
          const baseX = i * GAP + offsetX;
          const baseY = j * GAP + offsetY;

          const dx = baseX - mouse.x;
          const dy = baseY - mouse.y;
          const dist = Math.sqrt(dx*dx + dy*dy);
          
          let proximity = Math.max(0, 1 - dist / INFLUENCE_RADIUS);
          let wave = Math.sin(dist * 0.025 - time * 3.2) * proximity * 14;
          let ambient = Math.sin(time * 1.2 + (i+j)*0.1) * 1.5;

          const x = baseX;
          const y = baseY + wave + ambient;

          const size = 1.5 + proximity * 2;
          const alpha = 0.1 + proximity * 0.4;

          ctx.beginPath();
          ctx.arc(x, y, size, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255, 122, 82, ${alpha})`;
          ctx.fill();
        }
      }
      requestAnimationFrame(render);
    };
    render();
  }

  // --- Custom Cursor ---
  const cursor = document.getElementById('cursor');
  document.addEventListener('mousemove', (e) => {
    if (cursor) {
      cursor.style.left = `${e.clientX}px`;
      cursor.style.top = `${e.clientY}px`;
    }
  });

  const interactives = document.querySelectorAll('a, button');
  interactives.forEach(el => {
    el.addEventListener('mouseenter', () => cursor?.classList.add('hovering'));
    el.addEventListener('mouseleave', () => cursor?.classList.remove('hovering'));
  });

  // --- Role Activation ---
  const roleCards = document.querySelectorAll('.role-card');
  const overlay = document.getElementById('agent-overlay');
  const overlayName = document.getElementById('agent-overlay-name');

  const activateRole = (name) => {
    if (overlay && overlayName) {
      overlayName.textContent = name;
      overlay.classList.add('active');
      setTimeout(() => {
        overlay.classList.remove('active');
      }, 2400);
    }
  };

  roleCards.forEach(card => {
    card.addEventListener('click', () => {
      const name = card.dataset.name || 'Agente';
      activateRole(name);
    });
  });

  // Keyboard shortcuts ⌘+1-6
  document.addEventListener('keydown', (e) => {
    if (e.metaKey || e.ctrlKey) {
      const num = parseInt(e.key);
      if (num >= 1 && num <= 6) {
        e.preventDefault();
        const targetCard = document.querySelector(`.role-card[data-role="0${num}"]`);
        if (targetCard) {
          const name = targetCard.dataset.name || 'Agente';
          activateRole(name);
        }
      }
    }
  });
</script>
